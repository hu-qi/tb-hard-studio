{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tb-hard Case Metadata",
  "type": "object",
  "required": [
    "case_id", "status", "version", "task_revision", "primary_category",
    "primary_language", "difficulty_dimensions", "purchaser_tag", "owner",
    "oracle_status", "redteam_status", "calibration_status", "release_status"
  ],
  "properties": {
    "case_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"},
    "status": {"enum": ["draft", "active", "oracle-passed", "redteam-passed", "calibrated", "validated", "released", "rejected"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "task_revision": {"type": "string", "minLength": 1},
    "primary_category": {"type": "string", "minLength": 1},
    "primary_language": {"type": "string", "minLength": 1},
    "secondary_technologies": {"type": "array", "items": {"type": "string"}},
    "difficulty_dimensions": {"type": "array", "minItems": 3, "items": {"type": "string"}},
    "purchaser_tag": {"type": "string", "minLength": 1},
    "owner": {"type": "string", "minLength": 1},
    "oracle_status": {"type": "string"},
    "redteam_status": {"type": "string"},
    "calibration_status": {"type": "string"},
    "release_status": {"type": "string"}
  },
  "additionalProperties": true
}
